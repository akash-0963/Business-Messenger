// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

model Tag {
  id        String           @id @default(auto()) @map("_id") @db.ObjectId
  name      String           @unique
  createdAt DateTime         @default(now())
  contacts  ContactTag[]
  campaigns CampaignTag[]
}

model Contact {
  id        String       @id @default(auto()) @map("_id") @db.ObjectId
  phone     String       @unique
  name      String?
  tags      ContactTag[]
  isValid   Boolean      @default(false)
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt
}

model ContactTag {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  contactId String   @db.ObjectId
  tagId     String   @db.ObjectId
  contact   Contact  @relation(fields: [contactId], references: [id], onDelete: Cascade)
  tag       Tag      @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@unique([contactId, tagId])
  @@index([tagId])
}

model Campaign {
  id                 String               @id @default(auto()) @map("_id") @db.ObjectId
  name               String?
  description        String?
  message            String?
  status             String               @default("draft") // 'draft', 'scheduled', 'active', 'sent', 'failed'
  tags               CampaignTag[]
  dateFrom           DateTime?            // For filtering contacts by creation date
  dateTo             DateTime?            // For filtering contacts by creation date
  totalRecipients    Int                  @default(0)
  successCount       Int                  @default(0)
  failureCount       Int                  @default(0)
  pendingCount       Int                  @default(0)
  sendImmediate      Boolean              @default(true)
  scheduledDate      DateTime?
  sentAt             DateTime?
  createdAt          DateTime             @default(now())
  updatedAt          DateTime             @updatedAt
  CampaignRecipient  CampaignRecipient[]
}

model CampaignTag {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId
  campaignId String   @db.ObjectId
  tagId      String   @db.ObjectId
  campaign   Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  tag        Tag      @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@unique([campaignId, tagId])
  @@index([campaignId])
  @@index([tagId])
}

model CampaignRecipient {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId
  campaignId String   @db.ObjectId
  phone      String
  status     String   // 'sent', 'failed', 'pending'
  error      String?
  sentAt     DateTime @default(now())
  Campaign   Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@index([campaignId])
}
